{
  "AppName": "SoccerManager",
  "ConnectionStrings": {
    "DefaultConnection": "Server=<Server_Name_Here>;Database=SoccerManager;Encrypt=false;Trusted_Connection=True;MultipleActiveResultSets=true",
    "Redis": "localhost:6379"
  },
  "AdminUser": {
    "Email": "<Email>",
    "UserName": "admin",
    "Password": "<Password>"
  },
  "AuditLogOptions": {
    "CleanupBatchSize": 1000,
    "RetentionMinutes": 129600
  },
  "BackgroundJobOptions": {
    "BatchSize": 100,
    "MaxRetries": 3,
    "PollingIntervalSeconds": 60,
    "StuckJobThresholdMinutes": 30
  },
  "DataProtectionOptions": {
    "StorageFlag": "EphemeralKeySet",
    "Certificates": [
      {
        "Base64": "<Base64Cert>",
        "Password": "<Password>"
      }
    ],
    "_Note": "StorageFlag: Controls whether the private key is persisted to disk (MachineKeySet/UserKeySet) or kept strictly in RAM (EphemeralKeySet). Defaults to EphemeralKeySet if missing. Use EphemeralKeySet for Linux/Docker/Azure, MachineKeySet for Windows IIS. Supports comma-separated strings (e.g., 'MachineKeySet,Exportable') via Enum.Parse."
  },
  "CacheOptions": {
    "Version": "V1",
    "_Note": "Version: Increment whenever breaking changes are made to cached data."
  },
  "RateLimitOptions": {
    "GlobalLimit": 5000,
    "GuestLimit": 20,
    "Minutes": 1,
    "UserLimit": 100,
    "WhiteList": [ "127.0.0.1", "::1", "admin-user-id" ]
  },
  "SecurityOptions": {
    "CookieTimeout": "14.00:00:00",
    "LoginConcurrencyMode": "Block",
    "ShouldRotateRefreshTokens": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
